{
  "themes": [
    {
      "id": "theme1",
      "name": "1. 经典默认分栏 (Classic Split)",
      "is_dark": false,
      "css": ""
    },
    {
      "id": "theme2",
      "name": "2. 赛博监控大屏 (Cyber Dashboard - 方块网格)",
      "is_dark": true,
      "css": "body.theme2{background:#0f172a;color:#fff;} .theme2 .grid-container{grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px;} .theme2 .vps-card{flex-direction:column;background:#1e293b;border:1px solid #334155;padding:25px;border-radius:16px;box-shadow:0 10px 15px -3px rgba(0,0,0,0.5);} .theme2 .vps-card:hover{transform:translateY(-5px);border-color:#38bdf8;} .theme2 .card-left{border-bottom:2px dashed #334155;padding-bottom:15px;margin-bottom:15px;} .theme2 .card-right{border-left:none;padding-left:0;display:grid;grid-template-columns:1fr 1fr;gap:15px;} .theme2 .stat-group{background:#0f172a;padding:15px 12px;border-radius:12px;margin:0;} .theme2 .stat-bar-full{display:none;} .theme2 .stat-header{flex-direction:column;align-items:flex-start;font-size:12px;color:#94a3b8;} .theme2 .stat-header span:last-child{font-size:20px;font-weight:900;margin-top:5px;color:#38bdf8;} .theme2 .stat-subtext{display:none;} .theme2 .card-title{font-size:18px;color:#fff;} .theme2 .card-meta{color:#94a3b8;} .theme2 .ping-box{background:#0f172a;border-color:#334155;} .theme2 .global-stats{background:#1e293b;border:1px solid #334155;} .theme2 .g-val{color:#fff;}"
    },
    {
      "id": "theme3",
      "name": "3. 极简 ServerStatus (Ultra Compact - 单行列表)",
      "is_dark": false,
      "css": "body.theme3{background:#f8fafc;color:#1e293b;} .theme3 .grid-container{grid-template-columns:1fr;} .theme3 .vps-card{flex-direction:row;align-items:center;padding:12px 20px;border-radius:8px;background:#fff;border:1px solid #e2e8f0;transition:background 0.2s;} .theme3 .vps-card:hover{transform:none;background:#f1f5f9;box-shadow:none;border-color:#cbd5e1;} .theme3 .card-left{flex:0 0 280px;display:flex;flex-direction:row;align-items:center;gap:15px;border:none;padding:0;margin:0;} .theme3 .card-title{width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;} .theme3 .card-meta, .theme3 .ping-box, .theme3 .card-badges{display:none;} .theme3 .card-right{flex:1;display:flex;flex-direction:row;align-items:center;border:none;padding:0;gap:20px;justify-content:flex-end;} .theme3 .stat-group{margin:0;flex:1;display:flex;flex-direction:row;align-items:center;gap:10px;max-width:180px;} .theme3 .stat-header{width:40px;font-size:12px;} .theme3 .stat-bar-full{height:6px;} .theme3 .stat-subtext{display:none;} .theme3 .speed-anim{font-family:monospace;font-size:13px;}"
    },
    {
      "id": "theme4",
      "name": "4. 硬核命令行 Terminal (CLI Style - 纯净代码)",
      "is_dark": true,
      "css": "body.theme4{background:#000;color:#0f0;font-family:'Courier New',Courier,monospace;} .theme4 .grid-container{grid-template-columns:1fr;gap:0;} .theme4 .vps-card{background:transparent;border:none;border-bottom:1px dashed #0f0;border-radius:0;box-shadow:none;flex-direction:column;padding:15px 0;} .theme4 .vps-card:hover{transform:none;box-shadow:none;background:#001a00;} .theme4 .card-left{border:none;padding:0;margin:0;display:flex;flex-direction:row;align-items:center;gap:10px;} .theme4 .card-title{color:#0f0;} .theme4 .card-title::before{content:\"root@node:~# \";color:#fff;font-weight:normal;} .theme4 .card-badges, .theme4 .ping-box{display:none;} .theme4 .stat-bar-full, .theme4 .stat-bar{display:none;} .theme4 .card-right{display:flex;flex-direction:row;flex-wrap:wrap;border:none;padding:10px 0 0 0;gap:20px;} .theme4 .stat-group{flex:0 0 auto;display:flex;flex-direction:row;align-items:center;margin:0;gap:5px;} .theme4 .stat-header{font-size:13px;color:#0f0;} .theme4 .stat-header span:first-child::after{content:\":\";} .theme4 .stat-subtext{display:none;} .theme4 .g-val, .theme4 .card-meta{color:#0f0;} .theme4 .status-dot{border-radius:0;width:10px;height:10px;} .theme4 .global-stats, .theme4 .view-controls, .theme4 .filter-tag{background:#000;border:1px solid #0f0;color:#0f0;border-radius:0;} .theme4 .toggle-btn.active, .theme4 .filter-tag.active{background:#0f0;color:#000;} .theme4 .toggle-btn{color:#0a0;}"
    },
    {
      "id": "theme5",
      "name": "5. 苹果灵动岛 (Dynamic Island - 上下翻转式)",
      "is_dark": false,
      "css": "body.theme5{background:#f5f5f7;font-family:-apple-system,BlinkMacSystemFont,sans-serif;} .theme5 .grid-container{grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:25px;} .theme5 .vps-card{flex-direction:column;background:rgba(255,255,255,0.8);backdrop-filter:blur(20px);border-radius:30px;padding:30px;border:1px solid #fff;box-shadow:0 10px 30px rgba(0,0,0,0.05);} .theme5 .vps-card:hover{transform:scale(1.02);box-shadow:0 15px 40px rgba(0,0,0,0.08);} .theme5 .card-right{order:-1;border:none;padding:0;margin-bottom:20px;border-bottom:1px solid #eee;padding-bottom:20px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;} .theme5 .card-left{justify-content:center;text-align:center;} .theme5 .card-title{justify-content:center;font-size:22px;font-weight:700;} .theme5 .ping-box{justify-content:center;border:none;background:transparent;} .theme5 .stat-group{margin:0;} .theme5 .stat-header{flex-direction:column;align-items:center;font-size:11px;color:#888;} .theme5 .stat-header span:last-child{font-size:16px;font-weight:700;color:#111;} .theme5 .stat-bar-full{height:10px;border-radius:5px;background:#e5e5ea;} .theme5 .stat-bar-full > div{background:linear-gradient(90deg,#34c759,#32d74b) !important;border-radius:5px;} .theme5 .stat-subtext{display:none;} .theme5 .card-meta{text-align:center;} .theme5 .global-stats{border-radius:30px;box-shadow:0 10px 30px rgba(0,0,0,0.05);}"
    },
    {
      "id": "theme6",
      "name": "6. Win8 磁贴风 (Metro UI - 纯色无边框色块)",
      "is_dark": true,
      "css": "body.theme6{background:#111;color:#fff;} .theme6 .grid-container{grid-template-columns:repeat(auto-fill,minmax(400px,1fr));gap:10px;} .theme6 .vps-card{flex-direction:row;background:#0078D7;border-radius:0;border:none;color:#fff;padding:20px;box-shadow:none;} .theme6 .vps-card:hover{transform:none;box-shadow:inset 0 0 0 3px rgba(255,255,255,0.5);background:#005A9E;} .theme6 .card-left{flex:0 0 150px;border-right:2px solid rgba(255,255,255,0.2);border-bottom:none;padding:0 15px 0 0;margin:0 15px 0 0;} .theme6 .card-title{color:#fff;font-size:20px;font-weight:400;} .theme6 .card-meta, .theme6 .ping-box{color:#eee;} .theme6 .card-right{display:grid;grid-template-columns:1fr 1fr;gap:15px;border:none;padding:0;} .theme6 .stat-bar-full{border-radius:0;background:rgba(255,255,255,0.3);height:14px;} .theme6 .stat-bar-full > div{border-radius:0;background:#fff !important;} .theme6 .stat-header{color:#fff;} .theme6 .stat-subtext{color:#ddd;} .theme6 .status-dot{border-radius:0;} .theme6 .badge{border-radius:0;background:rgba(0,0,0,0.3);border:none;} .theme6 .global-stats{background:#111;border:2px solid #333;border-radius:0;box-shadow:none;} .theme6 .g-val{color:#fff;}"
    },
    {
      "id": "theme7",
      "name": "7. 时光轴看板 (Timeline Flow - 垂直树状流)",
      "is_dark": false,
      "css": "body.theme7{background:#f9fafb;color:#333;} .theme7 .group-header{margin-left:20px;} .theme7 .grid-container{display:flex;flex-direction:column;border-left:4px solid #cbd5e1;margin-left:30px;padding-left:30px;gap:20px;} .theme7 .vps-card{position:relative;flex-direction:row;background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:20px;box-shadow:0 4px 6px -1px rgba(0,0,0,0.05);} .theme7 .vps-card:hover{border-color:#94a3b8;transform:translateX(5px);} .theme7 .vps-card::before{content:'';position:absolute;left:-41px;top:25px;width:18px;height:18px;background:#3b82f6;border-radius:50%;border:4px solid #f9fafb;} .theme7 .card-left{flex:0 0 200px;border-right:1px dashed #cbd5e1;border-bottom:none;padding-right:20px;margin-right:20px;margin-bottom:0;} .theme7 .card-right{display:flex;flex-direction:row;flex-wrap:wrap;gap:15px;border:none;padding:0;align-items:center;width:100%;} .theme7 .stat-group{flex:1 1 120px;margin:0;background:#f1f5f9;padding:12px;border-radius:8px;} .theme7 .stat-bar-full{height:6px;} .theme7 .ping-box{display:none;} .theme7 @media (max-width:768px){.theme7 .vps-card{flex-direction:column;}.theme7 .card-left{border-right:none;border-bottom:1px dashed #cbd5e1;padding-right:0;padding-bottom:15px;margin-right:0;}}"
    }
